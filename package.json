{
  "name": "@wyre-technology/unitrends-mcp",
  "version": "0.0.0",
  "description": "Unitrends Backup MCP server for Claude — appliances, jobs, recovery points, restores, replication, alerts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "unitrends-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:ui": "vite build && node scripts/embed-ui.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:mcpb": "node scripts/pack-mcpb.js",
    "validate:mcpb": "mcpb validate manifest.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyre-technology/unitrends-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "unitrends",
    "backup",
    "bcdr",
    "kaseya",
    "msp"
  ],
  "author": "Wyre Technology",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/wyre-technology/unitrends-mcp/issues"
  },
  "homepage": "https://github.com/wyre-technology/unitrends-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@wyre-technology/node-unitrends": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/ext-apps": "^1.7.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "semantic-release": "^25.0.8",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
